rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user owns the document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Helper: get user role from users collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && getUserRole() == 'admin';
    }

    function isVendor() {
      return isAuth() && getUserRole() == 'vendor';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // Machines collection
    match /machines/{machineId} {
      allow read: if true; // Public read for search
      allow create: if isVendor();
      allow update: if isAuth() && (resource.data.vendorId == request.auth.uid || isAdmin());
      allow delete: if isAuth() && (resource.data.vendorId == request.auth.uid || isAdmin());
    }

    // Bookings collection
    match /bookings/{bookingId} {
      allow read: if isAuth() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.vendorId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.vendorId == request.auth.uid ||
        isAdmin()
      );
    }

    // Estimates collection
    match /estimates/{estimateId} {
      allow read: if isAuth() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isAuth();
    }

    // Notifications collection
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Categories collection
    match /categories/{categoryId} {
      allow read: if true; // Public
      allow write: if isAdmin();
    }

    // Service Areas collection
    match /serviceAreas/{areaId} {
      allow read: if true; // Public
      allow write: if isAdmin();
    }
  }
}
