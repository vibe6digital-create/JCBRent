rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Machine images - vendors can upload, anyone can read
    match /machines/{vendorId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == vendorId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Estimate photos - authenticated users can upload their own
    match /estimates/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Profile images
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
