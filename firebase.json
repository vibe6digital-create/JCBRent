{
  "functions": {
    "source": "backend",
    "runtime": "nodejs20",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "src",
      "*.ts"
    ],
    "predeploy": [
      "npm --prefix backend install",
      "npm --prefix backend run build"
    ]
  },

  "hosting": [
    {
      "target": "customer",
      "public": "heavyrent-web/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/api/**", "function": "api" },
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css|woff2|woff|ttf)",
          "headers": [{ "key": "Cache-Control", "value": "max-age=31536000" }]
        }
      ],
      "predeploy": ["npm --prefix heavyrent-web run build"]
    },
    {
      "target": "admin",
      "public": "admin-panel/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/api/**", "function": "api" },
        { "source": "**", "destination": "/index.html" }
      ],
      "predeploy": ["npm --prefix admin-panel run build"]
    }
  ],

  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },

  "storage": {
    "rules": "storage.rules"
  }
}
